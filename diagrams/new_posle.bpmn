  <bpmn:collaboration id="Collab_1">
    <bpmn:participant id="Pool_Shop" name="Процесс обработки возврата товаров после внедрения АИС" processRef="Proc_1" />
    <bpmn:textAnnotation id="A1">
      <bpmn:text>Ввод наименования организации, или номера заказа</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ac1">
      <bpmn:text>Наименование, артикул, количество, причина, фото и видео</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ac4">
      <bpmn:text>Транспортировка на склад
отделом логистики</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ac5">
      <bpmn:text>Артикул, количество,
состояние упаковки,
повреждения</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1r8jtkn" associationDirection="None" sourceRef="M1" targetRef="A1" />
    <bpmn:textAnnotation id="TextAnnotation_0sk3hov">
      <bpmn:text>Присвоение статуса «отклонена» с указанием причины</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1cbjtxy">
      <bpmn:text>Подтягивание данных из 1С для создания заявки возврата и проверки условий возврата</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0011n4p" associationDirection="None" sourceRef="Activity_1l1bijj" targetRef="TextAnnotation_1cbjtxy" />
    <bpmn:association id="Association_0icy2i6" associationDirection="None" sourceRef="TextAnnotation_0sk3hov" targetRef="Activity_132pnof" />
    <bpmn:association id="Association_1c4g6y1" associationDirection="None" sourceRef="DataObjectReference_1a7pe43" targetRef="Ac1" />
  </bpmn:collaboration>
