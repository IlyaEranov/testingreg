<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Defs_1" targetNamespace="http://example.com/rs" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <bpmn:collaboration id="Collab_1">
    <bpmn:participant id="Pool_Shop" name="Существующий процесс обработки возврата товаров" processRef="Proc_1" />
    <bpmn:textAnnotation id="A1">
      <bpmn:text>Поиск заказа в 1С,
проверка срока по договору,
сохранности и причины</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ac1">
      <bpmn:text>Наименование, артикул,
количество, причина,
фото и видео</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ac4">
      <bpmn:text>Транспортировка на склад
отделом логистики</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ac5">
      <bpmn:text>Артикул, количество,
состояние упаковки,
повреждения</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Awo">
      <bpmn:text>Ручное заполнение формы
списания в 1С</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_18qrg3n" associationDirection="None" sourceRef="C4" targetRef="Ac4" />
    <bpmn:association id="Association_1bgotnl" associationDirection="None" sourceRef="Mwo" targetRef="Awo" />
    <bpmn:association id="Association_19yxy9u" associationDirection="None" sourceRef="DataObjectReference_0rp9f5d" targetRef="A1" />
    <bpmn:association id="Association_10fo9i1" associationDirection="None" sourceRef="DataObjectReference_15y2t57" targetRef="Ac1" />
    <bpmn:association id="Association_104n6jk" associationDirection="None" sourceRef="DataObjectReference_03nyz90" targetRef="Ac5" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Mgr" name="Менеджер">
        <bpmn:flowNodeRef>mStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>M1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>G1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>M2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Rbox</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>mEndR</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Mwo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>G4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Mact</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>mEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Mcor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>G3</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Claims" name="Сотрудник претензионного отдела">
        <bpmn:flowNodeRef>C1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>C2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>C3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Cg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>C4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1kkjlgv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>C5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>C6</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="mStart" name="Поступило обращение&#10;покупателя">
      <bpmn:outgoing>f1</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:startEvent>
    <bpmn:manualTask id="M1" name="Поиск и проверка заказа">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1bhwi3q">
        <bpmn:targetRef>DataObjectReference_0rp9f5d</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:manualTask>
    <bpmn:exclusiveGateway id="G1" name="Соответствует&#10;условиям возврата?">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f_yes</bpmn:outgoing>
      <bpmn:outgoing>f_no1</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:manualTask id="M2" name="Передача покупателю&#10;контакта претензионного отдела">
      <bpmn:incoming>f_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_04li60g</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="C1" name="Сбор сведений и материалов&#10;от покупателя">
      <bpmn:incoming>Flow_04li60g</bpmn:incoming>
      <bpmn:outgoing>Flow_1qj340s</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1x8t5tw">
        <bpmn:targetRef>DataObjectReference_15y2t57</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:manualTask>
    <bpmn:manualTask id="C2" name="Оформление и отправка&#10;претензии заводу-изготовителю">
      <bpmn:incoming>Flow_19iuwqx</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="C3" name="Получение&#10;заключения завода">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:exclusiveGateway id="Cg" name="Брак подтверждён?">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f_no2</bpmn:outgoing>
      <bpmn:outgoing>f_yes2</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:manualTask id="C4" name="Маршрутный лист,&#10;передача в отдел логистики">
      <bpmn:incoming>f_no2</bpmn:incoming>
      <bpmn:incoming>Flow_10jfihz</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="Rbox" name="Формирование&#10;уведомления об отказе">
      <bpmn:incoming>f_no1</bpmn:incoming>
      <bpmn:incoming>f_yes2</bpmn:incoming>
      <bpmn:outgoing>f14</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:endEvent id="mEndR" name="Уведомление покупателя&#10;об отказе">
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:messageEventDefinition />
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_1kkjlgv" name="Причина возврата брак?">
      <bpmn:incoming>Flow_1qj340s</bpmn:incoming>
      <bpmn:outgoing>Flow_19iuwqx</bpmn:outgoing>
      <bpmn:outgoing>Flow_10jfihz</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:manualTask id="Mwo" name="Списание товара&#10;в 1С">
      <bpmn:incoming>f_brak</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:exclusiveGateway id="G4" name="">
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:manualTask id="Mact" name="Отправка акта&#10;сверки покупателю">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:endEvent id="mEnd" name="Возврат&#10;завершён">
      <bpmn:incoming>f13</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:manualTask id="Mcor" name="Корректировка остатков,&#10;возврат в продажу">
      <bpmn:incoming>f_neakt</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="C5" name="Приёмка и сверка&#10;товара">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0f2hwc5">
        <bpmn:targetRef>DataObjectReference_03nyz90</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:manualTask>
    <bpmn:manualTask id="C6" name="Передача результата&#10;менеджеру">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>Flow_1th7go7</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:exclusiveGateway id="G3" name="Результат&#10;обработки?">
      <bpmn:incoming>Flow_1th7go7</bpmn:incoming>
      <bpmn:outgoing>f_brak</bpmn:outgoing>
      <bpmn:outgoing>f_neakt</bpmn:outgoing>
    </bpmn:exclusiveGateway>
