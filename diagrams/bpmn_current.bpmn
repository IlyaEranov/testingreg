<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Defs_1" targetNamespace="http://example.com/rs">
  <bpmn:collaboration id="Collab_1">
    <bpmn:participant id="Pool_Shop" name="Существующий процесс обработки возврата товаров" processRef="Proc_1" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Mgr" name="Менеджер">
        <bpmn:flowNodeRef>mStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>M1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>G1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>M2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Rbox</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>mEndR</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>G3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Mwo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Mcor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>G4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Mact</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>mEnd</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Claims" name="Сотрудник претензионного отдела">
        <bpmn:flowNodeRef>C1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>C2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>C3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Cg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>C4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>C5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>C6</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="mStart" name="Поступило обращение
покупателя"><bpmn:outgoing>f1</bpmn:outgoing><bpmn:messageEventDefinition/></bpmn:startEvent>
    <bpmn:userTask id="M1" name="Идентификация заказа в 1С
и проверка условий возврата"><bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="G1" name="Соответствует
условиям возврата?"><bpmn:incoming>f2</bpmn:incoming><bpmn:outgoing>f_yes</bpmn:outgoing><bpmn:outgoing>f_no1</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="M2" name="Передача покупателю
контакта претензионного отдела"><bpmn:incoming>f_yes</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="Rbox" name="Формирование
уведомления об отказе"><bpmn:incoming>f_no1</bpmn:incoming><bpmn:incoming>f_yes2</bpmn:incoming><bpmn:outgoing>f14</bpmn:outgoing></bpmn:userTask>
    <bpmn:endEvent id="mEndR" name="Уведомление
об отказе"><bpmn:incoming>f14</bpmn:incoming><bpmn:messageEventDefinition/></bpmn:endEvent>
    <bpmn:exclusiveGateway id="G3" name="Результат
обработки?"><bpmn:incoming>f9</bpmn:incoming><bpmn:outgoing>f_brak</bpmn:outgoing><bpmn:outgoing>f_neakt</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="Mwo" name="Списание товара
в 1С"><bpmn:incoming>f_brak</bpmn:incoming><bpmn:outgoing>f10</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="Mcor" name="Корректировка остатков,
возврат в продажу"><bpmn:incoming>f_neakt</bpmn:incoming><bpmn:outgoing>f11</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="G4" name=""><bpmn:incoming>f10</bpmn:incoming><bpmn:incoming>f11</bpmn:incoming><bpmn:outgoing>f12</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="Mact" name="Отправка акта
сверки покупателю"><bpmn:incoming>f12</bpmn:incoming><bpmn:outgoing>f13</bpmn:outgoing></bpmn:userTask>
    <bpmn:endEvent id="mEnd" name="Возврат
завершён"><bpmn:incoming>f13</bpmn:incoming></bpmn:endEvent>
    <bpmn:userTask id="C1" name="Сбор сведений и материалов
от покупателя"><bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="C2" name="Оформление и отправка
претензии заводу-изготовителю"><bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="C3" name="Получение
заключения завода"><bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="Cg" name="Нарушение
эксплуатации?"><bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>f_no2</bpmn:outgoing><bpmn:outgoing>f_yes2</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="C4" name="Маршрутный лист,
передача в отдел логистики"><bpmn:incoming>f_no2</bpmn:incoming><bpmn:outgoing>f7</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="C5" name="Приёмка и сверка
товара"><bpmn:incoming>f7</bpmn:incoming><bpmn:outgoing>f8</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="C6" name="Передача результата
менеджеру"><bpmn:incoming>f8</bpmn:incoming><bpmn:outgoing>f9</bpmn:outgoing></bpmn:userTask>
    <bpmn:sequenceFlow id="f1" sourceRef="mStart" targetRef="M1" />
    <bpmn:sequenceFlow id="f2" sourceRef="M1" targetRef="G1" />
    <bpmn:sequenceFlow id="f_yes" name="Да" sourceRef="G1" targetRef="M2" />
    <bpmn:sequenceFlow id="f3" sourceRef="M2" targetRef="C1" />
    <bpmn:sequenceFlow id="f4" sourceRef="C1" targetRef="C2" />
    <bpmn:sequenceFlow id="f5" sourceRef="C2" targetRef="C3" />
    <bpmn:sequenceFlow id="f6" sourceRef="C3" targetRef="Cg" />
    <bpmn:sequenceFlow id="f_no2" name="Нет" sourceRef="Cg" targetRef="C4" />
    <bpmn:sequenceFlow id="f7" sourceRef="C4" targetRef="C5" />
    <bpmn:sequenceFlow id="f8" sourceRef="C5" targetRef="C6" />
    <bpmn:sequenceFlow id="f9" sourceRef="C6" targetRef="G3" />
    <bpmn:sequenceFlow id="f_brak" name="брак" sourceRef="G3" targetRef="Mwo" />
    <bpmn:sequenceFlow id="f_neakt" name="неактуальный" sourceRef="G3" targetRef="Mcor" />
    <bpmn:sequenceFlow id="f10" sourceRef="Mwo" targetRef="G4" />
    <bpmn:sequenceFlow id="f11" sourceRef="Mcor" targetRef="G4" />
    <bpmn:sequenceFlow id="f12" sourceRef="G4" targetRef="Mact" />
    <bpmn:sequenceFlow id="f13" sourceRef="Mact" targetRef="mEnd" />
    <bpmn:sequenceFlow id="f_no1" name="Нет" sourceRef="G1" targetRef="Rbox" />
    <bpmn:sequenceFlow id="f_yes2" name="Да" sourceRef="Cg" targetRef="Rbox" />
    <bpmn:sequenceFlow id="f14" sourceRef="Rbox" targetRef="mEndR" />
    <bpmn:textAnnotation id="A1"><bpmn:text>Ручной поиск заказа в 1С,
проверка срока по договору,
сохранности и причины</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Awo"><bpmn:text>Ручное оформление
списания в 1С</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ac1"><bpmn:text>Наименование, артикул,
количество, причина,
фото и видео</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ac3"><bpmn:text>Заводской брак / нарушение
эксплуатации / транспортное
повреждение</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ac4"><bpmn:text>Транспортировка на склад
отделом логистики</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ac5"><bpmn:text>Артикул, количество,
состояние упаковки,
повреждения</bpmn:text></bpmn:textAnnotation>
    <bpmn:association id="as_A1" sourceRef="M1" targetRef="A1" />
    <bpmn:association id="as_Awo" sourceRef="Mwo" targetRef="Awo" />
    <bpmn:association id="as_Ac1" sourceRef="C1" targetRef="Ac1" />
    <bpmn:association id="as_Ac3" sourceRef="C3" targetRef="Ac3" />
    <bpmn:association id="as_Ac4" sourceRef="C4" targetRef="Ac4" />
    <bpmn:association id="as_Ac5" sourceRef="C5" targetRef="Ac5" />
  </bpmn:process>
